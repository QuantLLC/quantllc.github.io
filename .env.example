# Copy to `.env.local` and fill in with your real Firebase project values for
# production. These are NOT required for local development, which uses the
# Firebase Emulator Suite automatically.
#
# Firebase web API keys are safe to expose in client-side code; access is
# controlled by Firebase Security Rules, not by keeping the key secret.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to force-connect a production build to local emulators.
# Leave empty in production.
VITE_USE_EMULATORS=
